{
  "definitions": [
    {
      "title": "Spotlight",
      "id": "spotlight",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Spotlight",
              "filter": "spotlight"
            }
          }
        }
      }
    },
    {
      "title": "Spotlight Card",
      "id": "spotlight-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Spotlight Card",
              "model": "spotlight-card",
              "titleType": "h3"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "spotlight-card",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Background Image",
          "multi": false
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title",
          "valueType": "string",
          "validation": {
            "maxLength": 15,
            "customErrorMsg": "Title must be 15 characters or less."
          }
        },
        {
          "component": "textarea",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "validation": {
            "maxLength": 40,
            "customErrorMsg": "Description must be 40 characters or less."
          }
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Link URL",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "Link Label",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "linkTarget",
          "label": "Link Target",
          "valueType": "string",
          "value": "_self",
          "options": [
            {
              "name": "Same window",
              "value": "_self"
            },
            {
              "name": "New tab",
              "value": "_blank"
            }
          ]
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "spotlight",
      "components": [
        "spotlight-card"
      ]
    }
