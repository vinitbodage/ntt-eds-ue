{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Title",
          "id": "title",
          "model": "title",
          "plugins": {
            "da": {
              "unsafeHTML": "<h2></h2>",
              "fields": [
                {
                  "name": "title",
                  "selector": "h2"
                }
              ]
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        },
        {
          "title": "Button",
          "id": "button",
          "model": "button",
          "plugins": {
            "da": {
              "unsafeHTML": "<p class=\"button-container\"><a href=\"\" title=\"\"></a></p>",
              "fields": [
                {
                  "name": "link",
                  "selector": "a[href]"
                },
                {
                  "name": "linkText",
                  "selector": "a"
                },
                {
                  "name": "linkTitle",
                  "selector": "a[title]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        },
        {
          "title": "Content Stack Section",
          "id": "content-stack-section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "content-stack-section",
          "model": "content-stack-section"
        }
      ]
    },
