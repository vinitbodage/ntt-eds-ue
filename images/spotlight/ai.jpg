var acceptedEloquaCookie = false;
var acceptedDemandBaseCookie = false;
var acceptedUTMCookie = false;
var verbose = true;
var performingSPScan = true;

function startIntervalTimer() {
	setInterval(() => {
		getEloquaStatus();
		getDemandBaseStatus();
		getUTMStatus();
    }, 2000);
}

function getEloquaStatus() {
    //console.log("checking Eloqua status...");
if(performingSPScan){acceptedEloquaCookie = true;return;}
	if(typeof sp !== 'undefined'){
		if(sp.checkConsent("Eloqua")==true)
		{
			acceptedEloquaCookie = true;
		}
		else 
		{
			acceptedEloquaCookie = false;
		}
		if(verbose){console.log("Eloqua status is: "+acceptedEloquaCookie);}
	}
	else{
		console.log("sp not defined");
	}
}

function getDemandBaseStatus() {
if(performingSPScan){acceptedDemandBaseCookie = true;return;}
    //console.log("checking DemandBase status...");
	if(typeof sp !== 'undefined'){
		if(sp.checkConsent("Demandbase")==true)
		{
			acceptedDemandBaseCookie = true;
		}
		else 
		{
			acceptedDemandBaseCookie = false;
		}
		if(verbose){console.log("DemandBase status is: "+acceptedDemandBaseCookie);}
	}
	else{
		console.log("sp not defined");
	}
}


function getUTMStatus() {
    //console.log("checking UTM status...");
if(performingSPScan){acceptedUTMCookie = true;return;}
	if(typeof sp !== 'undefined'){
		if(sp.checkConsent("Leadfeeder")==true)
		{
			acceptedUTMCookie = true;
		}
		else 
		{
			acceptedUTMCookie = false;
		}
		if(verbose){console.log("UTM status is: "+acceptedUTMCookie);}
	}
	else{
		console.log("sp not defined");
	}
}

startIntervalTimer();
