{
  "name": "@adobe/aem-boilerplate",
  "private": true,
  "version": "1.3.0",
  "description": "Starter project for Adobe Helix",
  "scripts": {
    "lint:js": "eslint . --ext .json,.js,.mjs",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "build:json": "npm-run-all -s build:json:stage build:json:merge",
    "build:json:stage": "npm-run-all -p build:json:stage:xwalk:models build:json:stage:xwalk:definitions build:json:stage:xwalk:filters build:json:stage:da:models build:json:stage:da:definitions build:json:stage:da:filters",
    "build:json:stage:xwalk:models": "merge-json-cli -i \"models/_component-models.json\" -o \".tmp/xwalk-component-models.json\"",
    "build:json:stage:xwalk:definitions": "merge-json-cli -i \"models/_component-definition.json\" -o \".tmp/xwalk-component-definition.json\"",
    "build:json:stage:xwalk:filters": "merge-json-cli -i \"models/_component-filters.json\" -o \".tmp/xwalk-component-filters.json\"",
    "build:json:stage:da:models": "merge-json-cli -i \"ue/models/component-models.json\" -o \".tmp/da-component-models.json\"",
    "build:json:stage:da:definitions": "merge-json-cli -i \"ue/models/component-definition.json\" -o \".tmp/da-component-definition.json\"",
    "build:json:stage:da:filters": "merge-json-cli -i \"ue/models/component-filters.json\" -o \".tmp/da-component-filters.json\"",
    "build:json:merge": "node tools/build/merge-component-json.mjs",
    "dev": "npx @adobe/aem-cli up --no-open --forward-browser-logs --stop-other",
    "dev:drafts": "npx @adobe/aem-cli up --no-open --forward-browser-logs --html-folder drafts --stop-other",
    "dev:proxy": "npx @adobe/aem-cli up --no-open --forward-browser-logs --stop-other --url https://main--ntt-eds-ue--vinitbodage.aem.page",
    "import:setup": "node tools/importer/setup-ui.mjs",
    "import:ui": "node tools/importer/setup-ui.mjs && npx @adobe/aem-cli import --no-open --stop-other",
    "import:service": "node tools/importer/run-service-import.mjs",
    "aem-upload": "aem-import-helper aem upload",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/aem-boilerplate.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/adobe/aem-boilerplate/issues"
  },
  "homepage": "https://github.com/adobe/aem-boilerplate#readme",
  "devDependencies": {
    "@adobe/aem-cli": "^16.20.7",
    "@adobe/aem-import-helper": "^1.6.0",
    "@babel/eslint-parser": "7.28.6",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-json": "3.1.0",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk",
    "husky": "9.1.1",
    "merge-json-cli": "1.0.4",
    "npm-run-all": "4.1.5",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0"
  }
}
