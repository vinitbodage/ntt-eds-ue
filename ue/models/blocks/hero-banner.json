{
  "definitions": [
    {
      "title": "Hero Banner",
      "id": "hero-banner",
      "model": "hero-banner",
      "filter": "hero-banner",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 1
        }
      }
    },
    {
      "title": "Hero Banner Slide",
      "id": "hero-banner-slide",
      "model": "hero-banner-slide",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "title", "selector": "div:nth-child(2)>h2" },
            { "name": "description", "selector": "div:nth-child(2)>p:nth-of-type(1)" },
            { "name": "link", "selector": "div:nth-child(2)>p>a[href]" },
            { "name": "linkTitle", "selector": "div:nth-child(2)>p>a" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "hero-banner-slide",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Banner Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "value": ""
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Banner Title",
          "validation": {
            "maxLength": 20,
            "customErrorMsg": "Banner title must be 20 characters or less."
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "description",
          "label": "Description",
          "validation": {
            "maxLength": 30,
            "customErrorMsg": "Description must be 30 characters or less."
          }
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Banner Link"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "linkTitle",
          "label": "Link Title"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "hero-banner",
      "components": ["hero-banner-slide"]
    }
  ]
}
