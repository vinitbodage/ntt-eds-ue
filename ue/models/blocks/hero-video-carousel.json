{
  "definitions": [
    {
      "title": "Hero Video Carousel",
      "id": "hero-video-carousel",
      "model": "hero-video-carousel",
      "filter": "hero-video-carousel",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 1
        }
      }
    },
    {
      "title": "Hero Video Carousel Slide",
      "id": "hero-video-carousel-slide",
      "model": "hero-video-carousel-slide",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "video", "selector": "div:nth-child(1)>video[src]" },
            { "name": "videoPoster", "selector": "div:nth-child(1)>video[poster]" },
            { "name": "title", "selector": "div:nth-child(2)>h2" },
            { "name": "ctaText", "selector": "div:nth-child(2)>p>a" },
            { "name": "cta", "selector": "div:nth-child(2)>p>a[href]" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "hero-video-carousel",
      "fields": [
        {
          "component": "number",
          "name": "autoplayDuration",
          "label": "Autoplay Duration (seconds)",
          "valueType": "number",
          "value": 8,
          "description": "Time each slide is shown before advancing automatically"
        },
        {
          "component": "boolean",
          "name": "autoplay",
          "label": "Autoplay",
          "valueType": "boolean",
          "value": true
        }
      ]
    },
    {
      "id": "hero-video-carousel-slide",
      "fields": [
        {
          "component": "reference",
          "name": "video",
          "label": "Video",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "reference",
          "name": "videoPoster",
          "label": "Video Poster",
          "valueType": "string",
          "multi": false,
          "description": "Fallback image shown before video loads; used for LCP"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "titleType",
          "label": "Title Level",
          "valueType": "string",
          "value": "h2",
          "options": [
            { "name": "H1", "value": "h1" },
            { "name": "H2", "value": "h2" }
          ]
        },
        {
          "component": "text",
          "name": "ctaText",
          "label": "CTA Text",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "cta",
          "label": "CTA Link",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "hero-video-carousel",
      "components": ["hero-video-carousel-slide"]
    }
  ]
}
