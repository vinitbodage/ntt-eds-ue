{
  "definitions": [
    {
      "title": "Spotlight",
      "id": "spotlight",
      "model": "spotlight",
      "filter": "spotlight",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 1
        }
      }
    },
    {
      "title": "Spotlight Card",
      "id": "spotlight-card",
      "model": "spotlight-card",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]" },
            { "name": "title", "selector": "div:nth-child(2)>h3" },
            { "name": "description", "selector": "div:nth-child(2)>p:nth-of-type(1)" },
            { "name": "link", "selector": "div:nth-child(2)>p>a[href]" },
            { "name": "linkText", "selector": "div:nth-child(2)>p>a" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "spotlight-card",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Background Image",
          "multi": false
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "title",
          "label": "Title",
          "valueType": "string",
          "validation": {
            "maxLength": 40,
            "customErrorMsg": "Title must be 40 characters or less."
          }
        },
        {
          "component": "textarea",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "validation": {
            "maxLength": 100,
            "customErrorMsg": "Description must be 100 characters or less."
          }
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Link URL",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "Link Label",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "linkType",
          "label": "Link Target",
          "valueType": "string",
          "value": "_self",
          "options": [
            { "name": "Same window", "value": "_self" },
            { "name": "New tab", "value": "_blank" }
          ]
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "spotlight",
      "components": ["spotlight-card"]
    }
  ]
}
